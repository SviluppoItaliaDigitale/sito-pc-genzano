# Redirect vecchio sito → nuovo sito
RewriteEngine On

# Pagine vecchie → nuove
Redirect 301 /chisiamo.html /chi-siamo/
Redirect 301 /contatti.html /contatti/
Redirect 301 /comunicazioni.html /comunicazioni/
Redirect 301 /allertameteo.html /allerte-meteo/
Redirect 301 /emergenza.html /piano-emergenza/
Redirect 301 /pianodiemergenza.html /piano-emergenza/
Redirect 301 /pianofamiliare.html /piano-familiare/
Redirect 301 /diventavolontario.html /diventa-volontario/
Redirect 301 /areadownload.html /area-download/
Redirect 301 /mappe.html /cartografia/
Redirect 301 /notelegali.html /note-legali/
Redirect 301 /privacy.html /privacy/
Redirect 301 /cerca.html /cerca/
Redirect 301 /sitiutili.html /siti-utili/
Redirect 301 /dichiarazione-accessibilita.html /accessibilita/
Redirect 301 /areerischio.html /rischi-prevenzione/
Redirect 301 /rischi.html /rischi-prevenzione/
Redirect 301 /rischio-sismico.html /rischi-prevenzione/rischio-sismico/
Redirect 301 /rischio-idrogeologico.html /rischi-prevenzione/rischio-idrogeologico/
Redirect 301 /rischio-incendio.html /rischi-prevenzione/rischio-incendio/
Redirect 301 /vulcano.html /rischi-prevenzione/rischio-vulcanico/
Redirect 301 /sanitario.html /numeri-utili/
Redirect 301 /cosafacciamo.html /chi-siamo/
Redirect 301 /simulatore.html /

# URL rinominati post-pubblicazione
Redirect 301 /formazione/kit-calamita-bambini/16-origami-cappello.html /formazione/kit-calamita-bambini/16-origami-barchetta.html
Redirect 301 /comunicazioni/2026-05-16-infiorata-genzano-2026/ /comunicazioni/2026-05-30-infiorata-genzano-2026/
Redirect 301 /comunicazioni/2026-05-16-infiorata-genzano-2026.html /comunicazioni/2026-05-30-infiorata-genzano-2026/

# Cartelle vecchie → nuove
Redirect 301 /assets/ /
Redirect 301 /cache/ /
Redirect 301 /immagini_web/ /

# 410 Gone esplicito per i .php legacy del vecchio pannello admin Joomla
# DEVE venire PRIMA del Redirect 301 della cartella /piano_protezione_civile/
# altrimenti il 301 scavalca e Google segue alla destinazione, ottenendo
# "soft 404" perché la query string (file=...&index=N) non viene preservata
# dal 301 della cartella. Il 410 dice esplicitamente a Google "andato per
# sempre, non re-crawlare". Report Search Console maggio 2026 mostrava
# 7+ URL elimina.php?file=...&index=N classificati come Soft 404.
RedirectMatch 410 ^/piano_protezione_civile/(elimina|aree|funzioni|scenari|genera_pdf|salva|modifica|carica)\.php(\?.*)?$

Redirect 301 /piano_protezione_civile/ /piano-emergenza/
Redirect 301 /sito_pc/ /
Redirect 301 /sitovecchio/ /

# /documenti/normativa/ → /area-download/normativa/ (file duplicati lì)
# /documenti/download/ NON reindirizzato — i PDF sono serviti direttamente
RedirectMatch 301 ^/documenti/normativa/(.*)$ /area-download/normativa/$1

# PDF storici del Piano serviti dalla root /documenti/ — Google Search
# Console segnala come "scansionati ma non indicizzati". Reindirizziamo
# alla cartella nuova del Piano.
RedirectMatch 301 ^/documenti/(Carta_di_.*\.pdf|Piano_di_.*\.pdf|Piano_Emergenza.*\.pdf|Aree_Emergenza.*\.pdf|Inquadramento_.*\.pdf|Rischio_.*\.pdf|Cartina_.*\.pdf)$ /area-download/normativa/$1

# URL Joomla "file_pii_*" del vecchio CMS (plugin Phoca o simile) —
# nessuna corrispondenza nel nuovo sito. Restituiamo 410 Gone per dire
# a Google che la pagina è definitivamente rimossa, così la elimina
# dall'indice subito invece di tenerla in coda.
RedirectMatch 410 ^/file_pii_.*$
RedirectMatch 410 ^/component/.*$
RedirectMatch 410 ^/option/.*$
RedirectMatch 410 ^/index\.php$
RedirectMatch 410 ^/joomla.*$

# Vecchi articoli /comunicazioni/AAAA/...html (CMS precedente). Il nuovo
# sito usa /comunicazioni/AAAA-MM-GG-slug/ senza estensione e senza anno
# come segmento. Reindirizziamo all'archivio /comunicazioni/.
RedirectMatch 301 ^/comunicazioni/[0-9]{4}/.*\.html?$ /comunicazioni/

# Vecchi nomi micro-siti standalone — il nuovo sito li chiama diversamente.
RedirectMatch 301 ^/giochi_protezione_civile/?(.*)$ /giochi/$1
RedirectMatch 301 ^/giochi-protezione-civile/?(.*)$ /giochi/$1
RedirectMatch 301 ^/formazione_pc/?(.*)$ /formazionepc/$1
RedirectMatch 301 ^/quiz_pc/?(.*)$ /quizpc/$1

# Pagine HTML standalone del vecchio sito senza corrispondenza diretta —
# 410 Gone (rimossa) così Google le toglie subito.
RedirectMatch 410 ^/galleria\.html$
RedirectMatch 410 ^/cookies-policy\.html$
RedirectMatch 410 ^/areefiltrate\.html$

# Le cartelle seguenti contengono risorse standalone sul server FTP
# e NON devono essere reindirizzate — i file sono serviti direttamente
# /cartelli/        — segnaletica aree di emergenza
# /giochi/          — giochi educativi per infanzia, primaria e ragazzi
# /formazionepc/    — piattaforma e-learning
# /quizpc/          — quiz interattivo

# Forza HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # geolocation: consentita al nostro stesso dominio (per "Centra sulla mia
  # posizione" sulla mappa cartografia). microphone e camera restano negati.
  Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
  Header always set X-XSS-Protection "1; mode=block"
  # HSTS: forza HTTPS per 1 anno, include sottodomini.
  # Il sito è già full-HTTPS (RewriteRule sopra fa 301 da http a https).
  # Aggiunto 2026-05-06 dopo audit security ChatGPT.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content-Security-Policy in MODALITÀ REPORT-ONLY (10 maggio 2026):
  # il browser valuta la policy MA non blocca niente — registra solo
  # le violazioni nella console DevTools. Periodo di test: 1-2 settimane.
  # Se non emergono regressioni reali sui widget click-to-load (Windy,
  # INGV) né sulla mappa cartografia (OpenStreetMap), si converte
  # l'header a Content-Security-Policy attivo (senza -Report-Only).
  #
  # Direttive:
  # - default-src 'self': fallback per tutte le risorse non specificate
  # - script-src 'unsafe-inline' 'unsafe-eval': richiesti da Hugo +
  #   Bootstrap Italia + Leaflet. Migrazione a nonces in futuro è
  #   possibile ma richiede modifiche a tutti i template
  # - style-src 'unsafe-inline': inline styles dagli shortcode + BS-Italia
  # - cdn.jsdelivr.net: Bootstrap Icons CSS
  # - img-src https: data: blob:: foto inline da Wikipedia/NASA/ecc. +
  #   data URI per loghi inline + blob URI per upload utente
  # - connect-src raw.githubusercontent.com: fetch CSV DPC opendatasicilia
  # - frame-src: widget click-to-load (Windy, INGV, MeteoAM, DPC)
  # - frame-ancestors 'self': anti-clickjacking (ridondante con X-Frame)
  # - form-action 'self': solo form interni (ricerca, contatti)
  # - base-uri 'self': anti-XSS via tag <base>
  # - object-src 'none': niente Flash/plugin obsoleti
  # - upgrade-insecure-requests: forza HTTPS sui rare http:// residui
  Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' https://raw.githubusercontent.com https://api.github.com https://*.openstreetmap.org https://*.tile.openstreetmap.org; frame-src https://embed.windy.com https://www.windy.com https://*.ingv.it https://terremoti.ingv.it https://www.youtube.com https://www.youtube-nocookie.com https://*.protezionecivile.gov.it https://*.regione.lazio.it https://mappe.protezionecivile.gov.it; frame-ancestors 'self'; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
</IfModule>

# Cache statica — asset immutabili
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/html "access plus 10 minutes"
</IfModule>

# Compressione gzip
# Nota 2026-05-10: aggiunto text/javascript (RFC 9239, MIME type moderno
# usato da Apache 2.4+ per i .js) — senza questa riga il bundle BS-Italia
# arrivava al browser non compresso (1 MB invece di ~250 KB), audit
# Lighthouse uses-text-compression segnalava 3.6 sec di savings persi.
# Aggiunti anche application/rss+xml, application/xml, text/xml per
# comprimere i 39 feed RSS auto-generati da Hugo.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/rss+xml application/xml text/xml image/svg+xml
</IfModule>

# Errore 404 personalizzato
ErrorDocument 404 /404.html
