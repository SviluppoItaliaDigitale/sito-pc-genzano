{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- $prodBase := .Site.Params.productionBaseURL | default .Site.BaseURL -}}
  {{- $basePath := (urls.Parse .Site.BaseURL).Path | default "/" -}}
  {{- range .Data.Pages -}}
  {{- if not .Params.noindex }}
  {{- $pagePath := strings.TrimPrefix $basePath .RelPermalink -}}
  <url>
    <loc>{{ printf "%s/%s" (strings.TrimRight "/" $prodBase) $pagePath | safeHTML }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
  {{/* AUTO-DISCOVERY delle URL statiche (vivono in /static/, non note ad Hugo).
       La convenzione del sito è: TUTTI i contenuti sono indicizzabili di default
       (robots index,follow). Eventuali esclusioni si fanno a livello di file
       singolo modificando la meta robots. Le directory iterate qui sotto
       NON richiedono manutenzione: aggiungendo una nuova sottocartella con
       index.html, comparirà automaticamente nel sitemap al prossimo build. */}}

  {{- /* 1. Schede stampabili: tutte le sottocartelle di /static/formazione/schede-stampabili/ tranne 'assets' */ -}}
  {{- with os.ReadDir "static/formazione/schede-stampabili" }}
    {{- range . }}
      {{- if and .IsDir (ne .Name "assets") }}
  <url>
    <loc>{{ printf "%s/formazione/schede-stampabili/%s/" (strings.TrimRight "/" $prodBase) .Name | safeHTML }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
      {{- end }}
    {{- end }}
  {{- end }}

  {{- /* 2. Giochi (tre fasce): sottocartelle di /static/giochi/<fascia>/ tranne 'assets' */ -}}
  {{- range slice "infanzia" "primaria" "ragazzi" }}
    {{- $fascia := . }}
    {{- with os.ReadDir (printf "static/giochi/%s" $fascia) }}
      {{- range . }}
        {{- if and .IsDir (ne .Name "assets") }}
  <url>
    <loc>{{ printf "%s/giochi/%s/%s/" (strings.TrimRight "/" $prodBase) $fascia .Name | safeHTML }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
        {{- end }}
      {{- end }}
    {{- end }}
  {{- end }}

  {{- /* 3. Abili a Proteggere: sottocartelle di /static/abili-a-proteggere/ */ -}}
  {{- with os.ReadDir "static/abili-a-proteggere" }}
    {{- range . }}
      {{- if and .IsDir (ne .Name "assets") }}
  <url>
    <loc>{{ printf "%s/abili-a-proteggere/%s/" (strings.TrimRight "/" $prodBase) .Name | safeHTML }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
      {{- end }}
    {{- end }}
  {{- end }}

  {{- /* 4. Listing pages (hub) — non sono Hugo content, dichiarate qui */ -}}
  {{- range slice "giochi/" "giochi/infanzia/" "giochi/primaria/" "giochi/ragazzi/" "abili-a-proteggere/" "formazione/schede-stampabili/" "quizpc/" "formazionepc/" }}
  <url>
    <loc>{{ printf "%s/%s" (strings.TrimRight "/" $prodBase) . | safeHTML }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  {{- end }}

  {{- /* 5. Quiz Formativo PC e Formazione PC: file .html (non directory) */ -}}
  {{- range slice "quizpc" "formazionepc" }}
    {{- $dir := . }}
    {{- with os.ReadDir (printf "static/%s" $dir) }}
      {{- range . }}
        {{- if and (not .IsDir) (strings.HasSuffix .Name ".html") }}
  <url>
    <loc>{{ printf "%s/%s/%s" (strings.TrimRight "/" $prodBase) $dir .Name | safeHTML }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
        {{- end }}
      {{- end }}
    {{- end }}
  {{- end }}
</urlset>
