{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- $prodBase := .Site.Params.productionBaseURL | default .Site.BaseURL -}}
  {{- $basePath := (urls.Parse .Site.BaseURL).Path | default "/" -}}
  {{- range .Data.Pages -}}
  {{- if not .Params.noindex }}
  {{- $pagePath := strings.TrimPrefix $basePath .RelPermalink -}}
  <url>
    <loc>{{ printf "%s/%s" (strings.TrimRight "/" $prodBase) $pagePath | safeHTML }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
  {{- $staticPaths := slice
    "giochi/" "giochi/infanzia/" "giochi/primaria/" "giochi/ragazzi/"
    "giochi/infanzia/tartaruga-saggia/" "giochi/infanzia/numero-emergenza/"
    "giochi/infanzia/suoni-emergenza/" "giochi/infanzia/memory-facile/"
    "giochi/primaria/memory/" "giochi/primaria/quiz/"
    "giochi/primaria/caccia-al-rischio/" "giochi/primaria/zaino-emergenza/"
    "giochi/primaria/semaforo-rischio/" "giochi/primaria/abbina-impara/"
    "giochi/primaria/cosa-faccio-se/" "giochi/primaria/anagrammi/"
    "giochi/primaria/cruciverba/" "giochi/primaria/puzzle-scenari/"
    "giochi/ragazzi/simulatore-coc/" "giochi/ragazzi/emergency-responder/"
    "giochi/ragazzi/mappa-rischio/" "giochi/ragazzi/radio-emergency/"
    "giochi/ragazzi/codice-arancione/"
  -}}
  {{- range $staticPaths }}
  <url>
    <loc>{{ printf "%s/%s" (strings.TrimRight "/" $prodBase) . | safeHTML }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {{- end }}
</urlset>
